# =============================================================================
# Mandari Marketing Website - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# All values shown are the defaults used by docker-compose.yml.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# These are read by the postgres service AND used to construct the connection
# string for the website service.
POSTGRES_USER=mandari
POSTGRES_PASSWORD=mandari_dev
POSTGRES_DB=mandari_website

# Override the assembled connection string (rare). Leave commented to let the
# website service build it automatically from POSTGRES_* above.
# WEBSITE_DATABASE_URL=postgresql://mandari:mandari_dev@postgres:5432/mandari_website

# -----------------------------------------------------------------------------
# Web service
# -----------------------------------------------------------------------------
# Host port to expose the Wagtail site on (container always listens on 8001).
WEBSITE_PORT=6500

# Django/Wagtail
DEBUG=True
WEBSITE_SECRET_KEY=dev-only-insecure-change-me-when-deploying
SITE_URL=http://localhost:6500
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:6500,http://127.0.0.1:6500

# -----------------------------------------------------------------------------
# Cross-service links (optional for local-only testing)
# -----------------------------------------------------------------------------
# Where the marketing website can reach the main Mandari API (used by some
# server-rendered widgets that pull live counts/stats). Not required to run
# the site locally — the page just falls back to safe defaults.
MANDARI_API_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# Kener (self-hosted status page)
# -----------------------------------------------------------------------------
# Public host port for the Kener UI.
KENER_PORT=6501
# Public origin URL — used by Kener for absolute links and CSRF protection.
# Must match the URL users actually open in the browser.
KENER_ORIGIN=http://localhost:6501
# Random secret used by Kener for session signing. Generate with e.g.
#   openssl rand -base64 32
KENER_SECRET_KEY=dev-only-kener-secret-change-me

# Public URL of the live status page — used as the "open status page directly"
# fallback link on /status/. Override only if Kener runs behind a reverse
# proxy on a different domain (e.g. https://status.mandari.de).
STATUS_PAGE_URL=http://localhost:6501

# Server-side URL the marketing-site backend uses to call Kener's REST API.
# In Docker this is the internal service name (kener:3000). For local dev
# outside Docker, set it to the same host as STATUS_PAGE_URL.
KENER_INTERNAL_URL=http://kener:3000

# API token for Kener's REST API. Generate one after logging into the
# Kener admin (open http://localhost:6501/account/signin and create the
# first user; then go to Settings → API Keys). Without a token the
# /status/ page falls back to a "open status page directly" link — it
# never breaks the site.
KENER_API_TOKEN=

# -----------------------------------------------------------------------------
# Booking URL for "Call buchen" CTAs
# -----------------------------------------------------------------------------
# Default points to the internal native booking form on the contact page
# (/kontakt/#termin-buchen). Only override if you migrate to an external tool
# such as Cal.com, Calendly, Microsoft Bookings, etc.
BOOKING_URL=/kontakt/#termin-buchen

# -----------------------------------------------------------------------------
# Altcha (DSGVO-konformer, self-hosted Spam-Schutz)
# -----------------------------------------------------------------------------
# HMAC-Schlüssel für Challenge-Signierung. In Production:
#   openssl rand -hex 32
# erzeugt einen sicheren Wert. Niemals den Default in Production nutzen.
ALTCHA_HMAC_KEY=dev-only-altcha-secret-please-replace-in-production
# Maximaler Zahlenraum für den Proof-of-Work. 100000 = ~1 Sekunde auf modernen
# Geräten. Höher = sicherer, aber langsamer für legitime User.
ALTCHA_MAX_NUMBER=100000

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
TZ=Europe/Berlin
